# ─── AWS Configuration ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
S3_BUCKET_NAME=ai-doc-intelligence-uploads

# ─── LLM APIs ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_DEFAULT_PROVIDER=openai          # openai | bedrock | gemini
OPENAI_MODEL=gpt-4o
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ─── Database ───────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/dociq_analytics
DB_USERNAME=dociq
DB_PASSWORD=dociq_secret

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Application ────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8081
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
PYTHON_PIPELINE_URL=http://localhost:8090

# ─── Frontend ───────────────────────────────────────────────────────────────
REACT_APP_UPLOAD_SERVICE_URL=http://localhost:8081
REACT_APP_ANALYTICS_SERVICE_URL=http://localhost:8084
REACT_APP_EXTRACTION_SERVICE_URL=http://localhost:8083
